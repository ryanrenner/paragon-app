# Paragon MLS Lookup — environment variables
# Copy this file to `.env` and fill in values. Never commit `.env`.

# --- Paragon credentials (Great Plains Regional MLS) ---
PARAGON_USERNAME=
PARAGON_PASSWORD=

# --- OpenRouter AI ---
OPENROUTER_API_KEY=
# Model to use via OpenRouter (e.g. google/gemini-2.5-flash-lite, anthropic/claude-sonnet-4)
AI_MODEL=google/gemini-2.5-flash-lite
# Max tokens for AI response (default: 1000)
AI_MAX_TOKENS=1000

# --- App HTTP Basic Auth ---
APP_USERNAME=
APP_PASSWORD=

# --- Server ---
PORT=3000
SESSION_TTL_MINUTES=2

# --- Timezone for display (storage stays UTC) ---
TZ=America/Chicago
